# VerityLens 环境变量示例
# 复制为 .env 并填写真实值

# 飞牛 NAS 部署（可选）
FLY_NAS_HOST=
FLY_NAS_PORT=22
FLY_NAS_USER=
FLY_NAS_PATH=/volume1/docker/verity-lens

# LLM API（本地 Qwen2.5-7B 或 OpenAI 兼容）
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# 数据库
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=veritylens
POSTGRES_USER=
POSTGRES_PASSWORD=

# 向量库
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_API_KEY=

# 浏览器扩展 ID
CHROME_EXTENSION_ID=
FIREFOX_EXTENSION_ID=
EDGE_EXTENSION_ID=

# 主人配置
OWNER_GITHUB=hannanlsa
OWNER_EMAIL=
