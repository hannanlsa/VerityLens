# VerityLens 环境变量示例
# 复制为 .env 并填写真实值

# Docker 部署（可选，浏览器插件可独立运行）
# FastAPI 地址（插件设置中填入，如 http://192.168.1.100:61593）
DOCKER_API_URL=http://127.0.0.1:61593

# LLM API（Docker 内部 Ollama 或外部云端）
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# 云端模型（浏览器插件设置页配置，无需在此填写）
# DeepSeek: https://platform.deepseek.com/
# 智谱GLM: https://open.bigmodel.cn/
# 通义千问: https://dashscope.console.aliyun.com/
# 硅基流动: https://siliconflow.cn/
# Groq: https://console.groq.com/

# 飞牛 NAS 部署（可选）
FLY_NAS_HOST=
FLY_NAS_PORT=22
FLY_NAS_USER=
FLY_NAS_PATH=/volume1/docker/verity-lens

# 主人配置
OWNER_GITHUB=hannanlsa
OWNER_EMAIL=
